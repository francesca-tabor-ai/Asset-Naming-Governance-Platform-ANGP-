# Database (required for migrations and app)
DATABASE_URL=postgres://user:password@localhost:5432/angp

# Redis (required for BullMQ)
REDIS_URL=redis://localhost:6379

# DAM adapter (e.g. Bynder) - optional for Phase 1 stub
# DAM_PROVIDER=bynder
# BYNDER_BASE_URL=
# BYNDER_TOKEN=

# Alerts - optional
# SLACK_WEBHOOK_URL=
# TEAMS_WEBHOOK_URL=
# JIRA_BASE_URL=
# JIRA_TOKEN=

# Server
PORT=3000
