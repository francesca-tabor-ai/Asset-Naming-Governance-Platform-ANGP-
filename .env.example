# Database (required for migrations and app)
DATABASE_URL=postgres://user:password@localhost:5432/angp

# Redis (required for BullMQ)
REDIS_URL=redis://localhost:6379

# DAM adapter (e.g. Bynder) - optional for Phase 1 stub
# DAM_PROVIDER=bynder
# BYNDER_BASE_URL=
# BYNDER_TOKEN=

# Alerts - optional
# SLACK_WEBHOOK_URL=
# TEAMS_WEBHOOK_URL=
# JIRA_BASE_URL=
# JIRA_TOKEN=

# Naming schema (optional; defaults in code)
# SCHEMA_CONFIG_PATH=./schema-config.json
# SCHEMA_SEPARATOR=-
# SCHEMA_CHANNEL_ALLOWLIST=IAB,Social,OOH,Display,Video,Print,DOOH,Email
# SCHEMA_FORMAT_DIMENSIONS_REGEX=^\d+x\d+$
# SCHEMA_LANGUAGE_ALLOWLIST=
# SCHEMA_MARKET_ALLOWLIST=
# SCHEMA_SEGMENT_ORDER=brand,product,campaign,channel,format,language,market

# Server
PORT=3000
